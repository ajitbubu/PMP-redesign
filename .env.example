# Google Analytics 4 measurement ID. GA is only injected when this is set.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Canonical site URL used by metadata, sitemap.ts and robots.ts.
NEXT_PUBLIC_SITE_URL=https://pmp.datasafeguard.ai

# Signs the session cookie (HMAC-SHA256). Required before deploying —
# without it, sessions fall back to a hardcoded insecure dev secret.
# Generate one with: openssl rand -base64 32
SESSION_SECRET=

# Resend API key for sending real OTP emails (https://resend.com/api-keys).
# Without it, OTP codes are logged to the server console instead of emailed —
# fully usable for local development, but nothing is actually delivered.
RESEND_API_KEY=
EMAIL_FROM="ID-PRIVACY <onboarding@resend.dev>"
